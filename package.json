{
  "name": "songster-monorepo",
  "private": true,
  "description": "Monorepo root — manages git hooks only. App lives in songster-svelte/.",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0"
  },
  "lint-staged": {
    "songster-svelte/**/*.{ts,svelte,css,json}": [
      "prettier --config songster-svelte/.prettierrc.json --write"
    ]
  }
}
