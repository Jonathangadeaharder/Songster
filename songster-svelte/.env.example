# ── Supabase (required) ────────────────────────────────────────────────────
# Find these in Supabase Dashboard → Project Settings → API

# Public URL exposed to the browser (safe to commit once set)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key — safe for browser, enforce RLS on every table
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — NEVER expose to the browser; only used in server hooks
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Music provider (optional — Deezer preview MVP requires no key) ──────────
# Uncomment if you add a server-side Deezer API proxy
# DEEZER_APP_ID=
# DEEZER_SECRET=

# ── Optional feature flags ──────────────────────────────────────────────────
# SPOTIFY_CLIENT_ID=          # Enable Spotify premium mode
# SPOTIFY_CLIENT_SECRET=
