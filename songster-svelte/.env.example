# ── Supabase (required) ────────────────────────────────────────────────────
# Find these in Supabase Dashboard → Project Settings → API

# Public URL exposed to the browser (safe to commit once set)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key — safe for browser, enforce RLS on every table
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — NEVER expose to the browser; only used in server hooks
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (for migrations script) ───────────────────────────────────────
# Direct Postgres connection string used by scripts/migrate.sh
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Docker Compose self-hosted ──────────────────────────────────────────────
# Only needed if running `docker compose up` for self-hosted Supabase
# POSTGRES_PASSWORD=your-super-secret-postgres-password
# GOTRUE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
# REALTIME_SECRET_KEY_BASE=your-super-secret-realtime-key-base-with-at-least-64-chars

# ── Node ────────────────────────────────────────────────────────────────────
# NODE_ENV=production   # Set automatically by Dockerfile; override if needed
# PORT=3000             # SvelteKit server port (default: 3000)

# ── Music provider (optional — Deezer preview MVP requires no key) ──────────
# Uncomment if you add a server-side Deezer API proxy
# DEEZER_APP_ID=
# DEEZER_SECRET=

# ── PostHog Analytics ──────────────────────────────────────────────────────
# Find these in PostHog Dashboard → Project Settings
PUBLIC_POSTHOG_PROJECT_TOKEN=your-posthog-project-token
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── AI Provider ──────────────────────────────────────────────────────────────
# Which AI backend to use. Supported: ollama | openrouter | groq | mini
# - ollama:    local Ollama for development (requires docker compose or native)
# - openrouter: OpenRouter API for cloud inference
# - groq:      Groq API for fast cloud inference
# - mini:      Local Ollama with small CPU-friendly models (phi, all-minilm) for
#              production on low-resource droplets (2vCPU/4GB)
AI_PROVIDER=ollama

# Base URL for the local Ollama instance (dev & mini providers)
LOCAL_AI_BASE_URL=http://localhost:11434/v1

# Base URL for production/cloud AI endpoints (openrouter, groq)
# Leave empty to use each provider's default
PROD_AI_BASE_URL=

# API keys for cloud providers (only needed with corresponding AI_PROVIDER)
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ── Optional feature flags ──────────────────────────────────────────────────
# SPOTIFY_CLIENT_ID=          # Enable Spotify premium mode
# SPOTIFY_CLIENT_SECRET=

# ── Docker Compose Production ───────────────────────────────────────────────
# When using docker-compose.prod.yml, all the above vars must be set in a
# .env file in the songster-svelte/ directory. Docker Compose reads it
# automatically and passes them to containers.
